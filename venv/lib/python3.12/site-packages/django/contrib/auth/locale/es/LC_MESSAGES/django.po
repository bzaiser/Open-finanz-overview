#, python-format
msgid "Change password: %s"
msgstr "Cambiar contraseña: %s"

#: venv/lib/python3.12/site-packages/django/contrib/auth/admin.py:208
#, python-format
msgid "Set password: %s"
msgstr "Establecer contraseña: %s"

