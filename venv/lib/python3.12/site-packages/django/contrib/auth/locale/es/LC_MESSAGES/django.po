msgstr "Restablecer contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:42
msgid "Set password"
msgstr "Establecer contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:85
msgid "The two password fields didn’t match."
msgstr "Los dos campos de contraseña no coinciden."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:89
#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:277
#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:313
msgid "Password"
msgstr "Contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:89
msgid "Password confirmation"
msgstr "Contraseña (confirmación)"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:102
msgid "Enter the same password as before, for verification."
msgstr "Para verificar, introduzca la misma contraseña anterior."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:149
msgid ""
"Whether the user will be able to authenticate using a password or not. If "
"disabled, they may still be able to authenticate using other backends, such "
"as Single Sign-On or LDAP."
msgstr ""
"Determina si el usuario podrá autenticarse usando una contraseña. Si está "
"deshabilitado, el usuario aún podría autenticarse mediante otros métodos, "
"como Single Sign-On o LDAP."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:157
msgid "Password-based authentication"
msgstr "Autenticación basada en contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:160
msgid "Enabled"
msgstr "Habilitado"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:160
msgid "Disabled"
msgstr "Deshabilitado"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:279
msgid ""
"Raw passwords are not stored, so there is no way to see the user’s password."
msgstr ""
"Las contraseñas en texto plano no se almacenan, por lo que no se puede ver "
"la contraseña del usuario."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:295
msgid ""
"Enable password-based authentication for this user by setting a password."
msgstr ""
"Habilite la autenticación por contraseña para este usuario estableciendo una "
"contraseña."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:320
#, python-format
msgid ""
"Please enter a correct %(username)s and password. Note that both fields may "
"be case-sensitive."
msgstr ""
"Por favor, introduzca un %(username)s y clave correctos. Observe que ambos "
"campos pueden ser sensibles a mayúsculas."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:323
msgid "This account is inactive."
msgstr "Esta cuenta está inactiva."

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:389
msgid "Email"
msgstr "Correo electrónico"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:498
msgid "New password"
msgstr "Contraseña nueva"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:498
msgid "New password confirmation"
msgstr "Contraseña nueva (confirmación)"

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:523
msgid "Your old password was entered incorrectly. Please enter it again."
msgstr ""
"Su contraseña antigua es incorrecta. Por favor, vuelva a introducirla. "

#: venv/lib/python3.12/site-packages/django/contrib/auth/forms.py:527
msgid "Old password"
msgstr "Contraseña antigua"

