#: venv/lib/python3.12/site-packages/django/contrib/auth/models.py:346
msgid "Specific permissions for this user."
msgstr "Permisos específicos para este usuario."

#: venv/lib/python3.12/site-packages/django/contrib/auth/models.py:457
msgid "username"
msgstr "nombre de usuario"

#: venv/lib/python3.12/site-packages/django/contrib/auth/models.py:461
msgid "Required. 150 characters or fewer. Letters, digits and @/./+/-/_ only."
msgstr ""
"Requerido. 150 carácteres como máximo. Únicamente letras, dígitos y @/./+/-/"
"_ "

#: venv/lib/python3.12/site-packages/django/contrib/auth/models.py:465
