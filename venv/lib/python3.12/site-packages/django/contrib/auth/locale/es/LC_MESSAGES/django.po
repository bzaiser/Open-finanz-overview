msgid "Permissions"
msgstr "Permisos"

#: venv/lib/python3.12/site-packages/django/contrib/auth/admin.py:59
msgid "Important dates"
msgstr "Fechas importantes"

#: venv/lib/python3.12/site-packages/django/contrib/auth/admin.py:156
#, python-format
msgid "%(name)s object with primary key %(key)r does not exist."
msgstr "el objeto %(name)s con clave primaria %(key)r no existe."

#: venv/lib/python3.12/site-packages/django/contrib/auth/admin.py:175
msgid "Conflicting form data submitted. Please try again."
msgstr ""
"Se enviaron datos contradictorios en el formulario. Por favor inténtalo de "
"nuevo."

