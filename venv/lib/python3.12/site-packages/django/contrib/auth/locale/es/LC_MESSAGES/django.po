#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:118
#, python-format
msgid "This password is too short. It must contain at least %d character."
msgid_plural ""
"This password is too short. It must contain at least %d characters."
msgstr[0] ""
"La contraseña es demasiado corta. Debe contener por lo menos %d carácter."
msgstr[1] ""
"La contraseña es demasiado corta. Debe contener por lo menos %d caracteres."
msgstr[2] ""
"La contraseña es demasiado corta. Debe contener por lo menos %d caracteres."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:127
#, python-format
msgid "Your password must contain at least %(min_length)d character."
msgid_plural "Your password must contain at least %(min_length)d characters."
msgstr[0] "Su contraseña debe contener al menos %(min_length)d caracter."
msgstr[1] "Su contraseña debe contener al menos %(min_length)d caracteres."
msgstr[2] "Su contraseña debe contener al menos %(min_length)d caracteres."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:216
#, python-format
msgid "The password is too similar to the %(verbose_name)s."
msgstr "La contraseña es demasiado similar a la de %(verbose_name)s."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:220
msgid "Your password can’t be too similar to your other personal information."
msgstr ""
"Su contraseña no puede asemejarse tanto a su otra información personal."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:258
msgid "This password is too common."
msgstr "Esta contraseña es demasiado común."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:261
msgid "Your password can’t be a commonly used password."
msgstr "Su contraseña no puede ser una clave utilizada comúnmente."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:277
msgid "This password is entirely numeric."
msgstr "Esta contraseña es completamente numérica."

#: venv/lib/python3.12/site-packages/django/contrib/auth/password_validation.py:280
msgid "Your password can’t be entirely numeric."
msgstr "Su contraseña no puede ser completamente numérica."

#: venv/lib/python3.12/site-packages/django/contrib/auth/templates/registration/password_reset_subject.txt:2
#, python-format
msgid "Password reset on %(site_name)s"
msgstr "Contraseña restablecida en %(site_name)s"

#: venv/lib/python3.12/site-packages/django/contrib/auth/templatetags/auth.py:12
msgid "No password set."
msgstr "No se ha establecido la clave."

#: venv/lib/python3.12/site-packages/django/contrib/auth/templatetags/auth.py:19
msgid "Invalid password format or unknown hashing algorithm."
msgstr "Formato de clave incorrecto o algoritmo de hash desconocido."

#: venv/lib/python3.12/site-packages/django/contrib/auth/validators.py:12
msgid ""
"Enter a valid username. This value may contain only unaccented lowercase a-z "
"and uppercase A-Z letters, numbers, and @/./+/-/_ characters."
msgstr ""
"Introduzca un nombre de usuario válido. Este valor solo puede contener "
"letras mayúsculas y minúsculas de la A la Z (excepto las acentuadas), "
"números y los caracteres @/./+/-/_."

#: venv/lib/python3.12/site-packages/django/contrib/auth/validators.py:22
msgid ""
"Enter a valid username. This value may contain only letters, numbers, and "
"@/./+/-/_ characters."
msgstr ""
"Introduza un nombre de usuario válido. Este valor puede contener únicamente "
"letras, números y los caracteres @/./+/-/_ "

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:160
msgid "Logged out"
msgstr "Sesión terminada"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:220
msgid "Password reset"
msgstr "Restablecer contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:244
msgid "Password reset sent"
msgstr "Restablecimiento de contraseña enviado"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:257
msgid "Enter new password"
msgstr "Escriba la nueva contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:328
msgid "Password reset unsuccessful"
msgstr "Restablecimiento de contraseñas fallido"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:338
msgid "Password reset complete"
msgstr "Restablecimiento de contraseña completado"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:353
msgid "Password change"
msgstr "Cambiar contraseña"

#: venv/lib/python3.12/site-packages/django/contrib/auth/views.py:371
msgid "Password change successful"
msgstr "Contraseña cambiada correctamente"
