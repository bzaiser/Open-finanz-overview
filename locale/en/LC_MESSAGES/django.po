msgid "HELP_TARGET_DATE"
msgstr "The target date for your financial simulation."

msgid "HELP_INFLATION_RATE"
msgstr ""
"The expected annual inflation rate that reduces the purchasing power of your "
"assets."

msgid "HELP_SALARY_INCREASE"
msgstr ""
"The average annual percentage by which your gross salary is expected to grow."

msgid "HELP_PENSION_INCREASE"
msgstr "The annual adjustment rate for your pension benefits."

msgid "HELP_INTEREST_BUFFER"
msgstr ""
"A global return premium applied to all your liquid assets (accounts and "
"investments)."

msgid "HELP_REAL_ESTATE_GROWTH"
msgstr "The expected annual value increase of your real estate properties."

