# ============================================================
# FINANZPLAN – DOCKER UMGEBUNGS-VARIABLEN
# ============================================================
# Kopiere diese Datei als '.env' in deinen Projektordner auf dem NAS.
# Ändere die Werte je nach Instanz (Privat vs. Public).

# --- INSTANZ-SPEZIFISCHE KONFIGURATION ---

# 1. Container Name (Muss auf dem NAS einzigartig sein)
# Beispiel Privat: finanzplan_privat
# Beispiel Public: finanzplan_public
CONTAINER_NAME=finanzplan_web

# 2. Image Name (Muss auf dem NAS einzigartig sein, falls du selbst baust)
# Beispiel Privat: finanzplan_privat_image
# Beispiel Public: finanzplan_public_image
IMAGE_NAME=finanzplan_image

# 3. Port (Muss auf dem NAS einzigartig sein)
# Beispiel Privat: 8000
# Beispiel Public: 8001
WEB_PORT=8000

# 3. Docker Compose Projekt Name (Isoliert Netzwerke & Volumes)
# Beispiel Privat: finanzplan_privat
# Beispiel Public: finanzplan_public
COMPOSE_PROJECT_NAME=finanzplan_instance

# --- SYSTEM-EINSTELLUNGEN ---
DEBUG=False
SECRET_KEY=Dein_Geheimer_Schluessel_Hier_Aeandern!
ALLOWED_HOSTS=*
RUNNING_IN_DOCKER=1

# --- INSTANZ-IDENTIFIKATION ---
# Zeigt den Namen im Header an (z.B. "Finanzplan (Private)")
# Hilfreich bei parallelem Betrieb von mehreren Instanzen.
APP_INSTANCE_NAME=Private

# --- AI / LLM KONFIGURATION ---
# LLM_PROVIDER wählt das Modell für die Bankbuchungs-Kategorisierung.
# Optionen: 
#   ollama  - (Empfohlen für Datenschutz) Komplett lokale KI-Analyse.
#   hybrid  - Versucht Cloud (Gemini/Groq), dann Fallback auf lokal/manuell.
#   gemini  - Google Gemini API (Cloud-basiert).
#   groq    - Groq Llama-3 API (Cloud-basiert, sehr schnell).
LLM_PROVIDER=ollama

# Ollama-Einstellungen (Privacy-Modus)
# Wenn 'ollama' als Provider gewählt ist, bleiben alle Finanzdaten im lokalen Netzwerk.
# OLLAMA_BASE_URL=http://<DEINE_IP>:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API-Keys (nur nötig bei hybrid, gemini oder groq)
GEMINI_API_KEY=
GROQ_API_KEY=
